@article{Chen2023,
  abstract = {We study the GMRES algorithm applied to linear systems of equations involving a scaled and shifted \textdollar N\textbackslash times N\textdollar  matrix whose entries are independent complex Gaussians. When the right hand side of this linear system is independent of this random matrix, the \textdollar N\textbackslash to\textbackslash infty\textdollar  behavior of the GMRES residual error can be determined exactly. To handle cases where the right hand side depends on the random matrix, we study the pseudospectra and numerical range of Ginibre matrices and prove a restricted version of Crouzeix\textquotesingle s conjecture.},
  author = {Chen, Tyler and Greenbaum, Anne and Trogdon, Thomas},
  eprint = {2303.02042v1},
  eprintclass = {math.NA},
  eprinttype = {arxiv},
  month = {3},
  title = {GMRES, pseudospectra, and Crouzeix\textquotesingle s conjecture for shifted and scaled Ginibre matrices},
  url = {http://arxiv.org/abs/2303.02042v1},
  year = {2023},
}

@article{Zhang2018,
  abstract = {We consider the application of the type-I Anderson acceleration to solving general non-smooth fixed-point problems. By interleaving with safe-guarding steps, and employing a Powell-type regularization and a re-start checking for strong linear independence of the updates, we propose the first globally convergent variant of Anderson acceleration assuming only that the fixed-point iteration is non-expansive. We show by extensive numerical experiments that many first order algorithms can be improved, especially in their terminal convergence, with the proposed algorithm. Our proposed method of acceleration is being implemented in SCS 2.0, one of the default solvers used in the convex optimization parser-solver CVXPY 1.0.},
  author = {Zhang, Junzi and O\textquotesingle Donoghue, Brendan and Boyd, Stephen},
  eprint = {1808.03971v1},
  eprintclass = {math.OC},
  eprinttype = {arxiv},
  month = {8},
  title = {Globally Convergent Type-I Anderson Acceleration for Non-Smooth Fixed-Point Iterations},
  url = {http://arxiv.org/abs/1808.03971v1},
  year = {2018},
}

@article{Bao2025,
  abstract = {For a square matrix, the range of its Rayleigh quotients is known as the numerical range, which is a compact and convex set by the Toeplitz-Hausdorff theorem. The largest value and the smallest boundary value (in magnitude) of this convex set are known as the numerical radius and inner numerical radius respectively. The numerical radius is often used to study the convergence rate of iterative methods for solving linear systems. In this work, we investigate these radii for complex non-Hermitian random matrix and its elliptic variants. For the former, remarkably, these radii can be represented as extrema of a stationary Airy-like process, which undergoes a correlation-decorrelation transition from small to large time scale. Based on this transition, we obtain the precise first and second order terms of the numerical radii. In the elliptic case, we prove that the fluctuation of the numerical radii boils down to the maximum or minimum of two independent Tracy-Widom variables.},
  author = {Bao, Zhigang and Cipolloni, Giorgio},
  eprint = {2510.02667v1},
  eprintclass = {math.PR},
  eprinttype = {arxiv},
  month = {10},
  title = {Numerical Radius of Non-Hermitian Random Matrices},
  url = {http://arxiv.org/abs/2510.02667v1},
  year = {2025},
}

